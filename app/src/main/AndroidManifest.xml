<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <queries>
        <package android:name="com.korail.talk" />
        <package android:name="kr.co.srail.newapp" />
    </queries>

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/app_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/app_icon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KtxTravelApplication"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".TravelPlanActivity"
            android:exported="false"
            android:theme="@style/AppTheme"/>
        <activity
            android:name=".TicketActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".PlanActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".TemaActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".MapActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".StartActivity"
            android:exported="true"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <meta-data
            android:name="com.naver.maps.map.CLIENT_ID"
            android:value="jzj6eb7fs1" />
    </application>

</manifest>